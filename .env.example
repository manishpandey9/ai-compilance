# ---- Database (local docker-compose) ----
DATABASE_URL=postgresql+asyncpg://aia:aia@localhost:5432/aia_navigator
DATABASE_URL_SYNC=postgresql://aia:aia@localhost:5432/aia_navigator

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Object storage (MinIO locally) ----
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=aia-documents
S3_REGION=us-east-1

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
SECRET_KEY=change-me-in-production

# ---- Auth (Clerk — optional for local dev) ----
CLERK_SECRET_KEY=
CLERK_JWKS_URL=

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_REPORT=
STRIPE_PRICE_EVIDENCE_PACK=

# ---- Email ----
RESEND_API_KEY=

# ---- Web / Admin ----
ADMIN_API_KEY=dev-admin-key
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# If :8000 is taken, run API on 8001 and set apps/web/.env.local → http://localhost:8001/api/v1
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ---- LLM (prose drafting only — optional) ----
LLM_API_KEY=
LLM_MODEL=
